// Example: Member Access (dot and :: operators)
struct Vec2 {
    x: float,
    y: float
}

enum Direction {
    North;
    South;
    East;
    West;
};

fn magnitude(v) {
    (v.x * v.x + v.y * v.y)
};

fn main() {
    let v = Vec2 { x: 3.0, y: 4.0 };
    print("v.x = " + v.x);
    print("v.y = " + v.y);
    print("|v|^2 = " + magnitude(v));

    // Enum variant access via ::
    let dir = Direction::North;
    print("Direction: North");
}
