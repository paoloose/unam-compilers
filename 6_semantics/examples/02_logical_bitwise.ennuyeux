// Example: Logical and Bitwise Operations
fn main() {
    // Logical
    let x = true;
    let y = false;

    print("true && false = " + (x && y));
    print("true || false = " + (x || y));
    print("!true = " + (!x));

    // Bitwise
    let a = 12;
    let b = 5;

    print("12 & 5  = " + (a & b));
    print("12 | 5  = " + (a | b));
    print("12 ^ 5  = " + (a ^ b));
    print("12 << 2 = " + (a << 2));
    print("12 >> 1 = " + (a >> 1));
    print("~12     = " + (~a));
}
