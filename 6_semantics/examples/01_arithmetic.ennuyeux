// Example: Basic Arithmetic and Variables
fn main() {
    let a: Int = 10;
    let b: Int = 3;

    print("a + b = " + (a + b));
    print("a - b = " + (a - b));
    print("a * b = " + (a * b));
    print("a / b = " + (a / b));
    print("a % b = " + (a % b));
    print("a ** b = " + (a ** b));

    // Unary negation
    let neg = -a;
    print("neg = " + neg);
}
